{
  "name": "pulse-desktop",
  "version": "1.1.2",
  "main": "dist/main/main.js",
  "author": "CodeWyse",
  "description": "Pulse — AI Work Companion",
  "scripts": {
    "dev": "tsc -p tsconfig.node.json && concurrently \"vite --config vite.config.ts\" \"tsc -p tsconfig.node.json --watch --preserveWatchOutput\" \"electron .\"",
    "build": "vite build --config vite.config.ts && tsc -p tsconfig.node.json",
    "build:main": "tsc -p tsconfig.node.json",
    "dist": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:all": "npm run build && electron-builder --win --mac",
    "start": "electron ."
  },
  "build": {
    "appId": "com.codewyse.pulse",
    "productName": "Pulse",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "icon": "build/icon.ico",
    "files": [
      "dist/**/*",
      "build/icon.ico",
      "build/icon.png",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Pulse"
    },
    "asar": true,
    "publish": [
      {
        "provider": "generic",
        "url": "https://backend.codewyse.site/downloads/update"
      }
    ]
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "antd": "^6.3.1",
    "axios": "^1.13.6",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "mediasoup-client": "^3.18.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "socket.io-client": "^4.8.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
