commands:
  01_install_chromium_and_deps:
    command: |
      sudo dnf install -y chromium pulseaudio ffmpeg dbus dbus-x11 \
        nss atk at-spi2-atk cups-libs libdrm libgbm \
        libXcomposite libXdamage libXfixes libXrandr libxshmfence \
        alsa-lib pango cairo gtk3 || \
      sudo amazon-linux-extras install -y epel && \
      sudo yum install -y chromium pulseaudio ffmpeg dbus dbus-x11 || true
    ignoreErrors: true
  02_start_pulseaudio_system:
    command: |
      sudo mkdir -p /var/run/dbus
      sudo dbus-daemon --system --fork || true
      sudo -u webapp pulseaudio --start --exit-idle-time=-1 || true
    ignoreErrors: true

option_settings:
  aws:elasticbeanstalk:application:environment:
    PUPPETEER_EXECUTABLE_PATH: /usr/bin/chromium-browser
    PUPPETEER_SKIP_DOWNLOAD: "true"
